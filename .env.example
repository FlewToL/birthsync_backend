APP_NAME=BirthSync API
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false
DB_APPLY_SCHEMA_ON_STARTUP=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Database settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=birthsync
DB_PASS=birthsync
DB_NAME=birthsync

# Redis settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=3

# GigaChat settings
CREDENTIALS=
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_VERIFY_SSL_CERTS=false

# Telegram Mini App auth verification
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
