APP_NAME=BirthSync API
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log
LOG_FILE_ROTATION=00:00
LOG_FILE_RETENTION=365 days
DB_APPLY_SCHEMA_ON_STARTUP=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173","https://birthsync.ru","https://www.birthsync.ru","https://birthsync-app-git-backend-integration-falcion-io.vercel.app"]
CORS_ORIGIN_REGEX=

# Database settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=birthsync
DB_PASS=birthsync
DB_NAME=birthsync

# Redis settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=3

# GigaChat settings
CREDENTIALS=
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_VERIFY_SSL_CERTS=false

# Telegram Mini App auth verification
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
TELEGRAM_BOT_REQUEST_TIMEOUT_SECONDS=30
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TELEGRAM_BOT_POLLING_ENABLED=false
TELEGRAM_REMINDERS_ENABLED=true
TELEGRAM_REMINDER_POLL_INTERVAL_SECONDS=60
TELEGRAM_REMINDER_LATE_GRACE_MINUTES=1440
TELEGRAM_REMINDER_TIMEZONE=Europe/Moscow
TELEGRAM_REMINDER_DEFAULT_TIME=09:00
